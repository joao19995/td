; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="td"
run/main_scene="scenes/main/Main.tscn"
config/features=PackedStringArray("4.7", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

EconomyManager="*uid://bpabpqj1km1wr"
EventBus="*uid://bxaicp3urfys8"
GameManager="*uid://bdyhlaph2hqex"
TowerPlacementManager="*uid://b8di4orayi46l"
SceneManager="*res://scripts/autoload/SceneManager.cs"
LevelManager="*uid://dua280ep3xp8a"
CameraManager="*uid://byeack2duep0v"
PoolManager="*res://scripts/systems/PoolManager.cs"
TowerSelectionManager="*res://scenes/system/TowerSelectionManager.tscn"
UIManager="*res://scenes/system/UIManager.tscn"
 
[display]

window/size/viewport_width=320
window/size/viewport_height=190
window/size/mode=1
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="td"

[gui]

theme/custom="uid://frsr3oi6eyiq"

